# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# --- Massive (stock data source) ---
MASSIVE_API_KEY=your_massive_api_key_here
MASSIVE_BASE_URL=https://api.massive.com

# --- App config ---
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,TSLA,NVDA
DDB_TABLE=stocks-movers

# --- AWS (for local Terraform/CDK deploy) ---
# Prefer `aws configure` / a named profile over putting keys here.
AWS_REGION=us-east-1
AWS_PROFILE=default
